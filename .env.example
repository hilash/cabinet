# Optional: set a password to protect the UI (leave empty for no auth)
KB_PASSWORD=

# Optional: domain for the app
DOMAIN=localhost

# Optional: override the shared data directory.
# Defaults to ./data for source installs, or a managed app-data path in Electron.
# CABINET_DATA_DIR=

# Optional: release manifest URL for update checks.
# CABINET_RELEASE_MANIFEST_URL=https://github.com/hilash/cabinet/releases/latest/download/cabinet-release.json

# Optional: override runtime ports and origins when embedding Cabinet in Electron.
# CABINET_APP_PORT=3000
# CABINET_DAEMON_PORT=3001
# CABINET_APP_ORIGIN=http://127.0.0.1:3000
# CABINET_PUBLIC_DAEMON_ORIGIN=ws://127.0.0.1:3001

# Meta Ads connector — required to run server/connectors/meta-ads.ts
# See server/connectors/README.md for step-by-step credential setup.
META_ADS_ACCESS_TOKEN=
META_ADS_AD_ACCOUNT_ID=

# Meta Ads connector — optional report window overrides.
# Default is a rolling 14-day window ending today. Set LOOKBACK_DAYS to change
# that, or set both START_DATE and END_DATE for an explicit one-off range.
# Dates must be in YYYY-MM-DD format.
# META_ADS_LOOKBACK_DAYS=14
# META_ADS_START_DATE=2026-03-01
# META_ADS_END_DATE=2026-03-31
