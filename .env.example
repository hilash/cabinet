# Optional: set a password to protect the UI (leave empty for no auth)
KB_PASSWORD=

# Optional: domain for the app
DOMAIN=localhost

# Optional: daemon port (default 3001)
CABINET_DAEMON_PORT=3001

# Optional: Next.js app URL for daemon callbacks (default http://localhost:3000)
CABINET_APP_URL=http://localhost:3000

# Optional: daemon URL for Next.js to reach the daemon (default http://127.0.0.1:3001)
CABINET_DAEMON_URL=http://127.0.0.1:3001
