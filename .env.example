# Optional: set a password to protect the UI (leave empty for no auth)
KB_PASSWORD=

# Optional: domain for the app
DOMAIN=localhost

# Optional: override the shared data directory.
# Defaults to ./data for source installs, or a managed app-data path in Electron.
# CABINET_DATA_DIR=

# Optional: release manifest URL for update checks.
# CABINET_RELEASE_MANIFEST_URL=https://github.com/hilash/cabinet/releases/latest/download/cabinet-release.json

# Optional: override runtime ports and origins when embedding Cabinet in Electron.
# CABINET_APP_PORT=3000
# CABINET_DAEMON_PORT=3001
# CABINET_APP_ORIGIN=http://127.0.0.1:3000
# CABINET_PUBLIC_DAEMON_ORIGIN=ws://127.0.0.1:3001

# Multica integration (optional — task management features)
# Set these to connect Cabinet to a running Multica server
MULTICA_API_URL=http://localhost:8080
NEXT_PUBLIC_MULTICA_API_URL=/multica-api
NEXT_PUBLIC_MULTICA_WS_URL=ws://localhost:8080/ws
# Dev mode only: PAT for auto-login (Electron mode generates this automatically)
# NEXT_PUBLIC_MULTICA_PAT=mul_xxx

# Multica daemon task poller — enable cabinet agents to receive and execute
# tasks assigned to them from Multica. Set to a personal access token (PAT)
# generated in Multica → Settings → Personal Access Tokens.
# Also add `multica_runtime_id: <uuid>` to each agent persona.md that should
# receive tasks. The runtime ID is visible in Multica → Settings → Runtimes.
# MULTICA_PAT=mul_xxx
