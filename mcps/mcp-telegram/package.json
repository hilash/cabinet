{
  "name": "cabinet-mcp-telegram",
  "version": "0.1.0",
  "description": "Cabinet-maintained, agent-shaped Telegram MCP server (Bot API). Safe-by-default: send / read-recent / react / manage in chats the bot was added to; destructive admin gated.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cabinet-mcp-telegram": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "telegram",
    "cabinet",
    "agent"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20",
    "esbuild": "^0.24.0",
    "typescript": "^5"
  }
}
